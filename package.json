{
  "name": "otto-skills-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal npx-based skills workflow with pinned versions and reproducible installs",
  "type": "module",
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "check": "npm run doctor",
    "skill:hello:local": "npm exec --yes --package=./skills/hello-skill-tool -- otto-hello --topic version-control --who team"
  }
}
